<html>
	<head>
		<% if (!isMobile) { %>
		<script
			type="text/javascript"
			src="https://<%= salesforceDomain %>/canvas/sdk/js/66.0/canvas-all.js"
		></script>
		<% } %>
	</head>
	<body>
		<h1 id="header">Canvas OAuth App</h1>

		<% if (isMobile) { %>
		<style>
			#login-container { display:flex; flex-direction:column; align-items:center; gap:12px; max-width:320px; margin:40px auto; text-align:center; }
			#login-button { padding:12px 24px; font-size:16px; background:#635dff; color:#fff; border:none; border-radius:4px; cursor:pointer; text-decoration:none; display:inline-block; }
			#login-error { color:red; font-size:14px; margin-top:8px; }
		</style>

		<div id="login-container">
			<h2>Sign in</h2>
			<p>You will be redirected to Auth0 to securely sign in with your email, password, and authenticator app.</p>
			<% if (typeof signedRequest !== 'undefined' && signedRequest) { %>
			<a id="login-button" href="/login-mobile-start?signed_request=<%= encodeURIComponent(signedRequest) %>">Sign in with Auth0</a>
			<% } else { %>
			<a id="login-button" href="/login-mobile-start">Sign in with Auth0</a>
			<% } %>
 			<% if (typeof error !== 'undefined' && error) { %>
			<div id="login-error"><%= error %></div>
			<% } %>
		</div>

		<% } else { %>

		<div>access_token = <span id="oauth"></span></div>
		<div><a id="loginAuth0" href="#" onclick="window.open('/login','auth0login','width=600,height=700'); return false;">Login Auth0</a><br /></div>
		<script>
			window.addEventListener('message', function(e) {
				if (e.data === 'auth0-success') {
					window.location.href = '/';
				}
			});
		</script>

		<% } %>
	</body>
</html>
