<html>
	<head>
		<% if (!isMobile) { %>
		<script
			type="text/javascript"
			src="https://<%= salesforceDomain %>/canvas/sdk/js/66.0/canvas-all.js"
		></script>
		<% } %>
	</head>
	<body>
		<h1 id="header">Canvas OAuth App</h1>

		<% if (isMobile) { %>
		<style>
			#login-form { display:flex; flex-direction:column; gap:12px; max-width:320px; margin:40px auto; }
			#login-form input { padding:10px; font-size:16px; border:1px solid #ccc; border-radius:4px; }
			#login-form button { padding:12px; font-size:16px; background:#635dff; color:#fff; border:none; border-radius:4px; cursor:pointer; }
			#login-form button:disabled { opacity:0.6; cursor:not-allowed; }
			#login-error { color:red; font-size:14px; }
			#mfa-section { display:none; flex-direction:column; gap:12px; }
			.mfa-help { font-size:14px; color:#666; }
		</style>

		<div id="login-form">
			<h2 id="login-title">Sign in</h2>
			<input type="hidden" id="signed_request" value="<%= typeof signedRequest !== 'undefined' ? signedRequest : '' %>" />

			<div id="credentials-section">
				<input type="email" id="email" placeholder="Email" required autocomplete="email" />
				<input type="password" id="password" placeholder="Password" required autocomplete="current-password" />
				<button type="button" id="login-btn">Login</button>
			</div>

			<div id="mfa-section">
				<p class="mfa-help">Enter the 6-digit code from your authenticator app:</p>
				<input type="text" id="otp" placeholder="6-digit code" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" />
				<button type="button" id="mfa-btn">Verify</button>
			</div>

			<% if (typeof error !== 'undefined' && error) { %>
			<div id="login-error"><%= error %></div>
			<% } else { %>
			<div id="login-error"></div>
			<% } %>
		</div>

		<script>
			(function() {
				let mfaToken = null;
				const signedRequest = document.getElementById('signed_request').value;

				function showError(msg) {
					document.getElementById('login-error').textContent = msg;
				}

				function clearError() {
					document.getElementById('login-error').textContent = '';
				}

				function showMfaSection() {
					document.getElementById('credentials-section').style.display = 'none';
					document.getElementById('mfa-section').style.display = 'flex';
					document.getElementById('login-title').textContent = 'Verify with Authenticator';
					document.getElementById('otp').focus();
				}

				function showCredentialsSection() {
					document.getElementById('credentials-section').style.display = 'flex';
					document.getElementById('mfa-section').style.display = 'none';
					document.getElementById('login-title').textContent = 'Sign in';
					document.getElementById('otp').value = '';
					mfaToken = null;
				}

				function renderApp(html) {
					document.open();
					document.write(html);
					document.close();
				}

				document.getElementById('login-btn').addEventListener('click', async () => {
					const email = document.getElementById('email').value.trim();
					const password = document.getElementById('password').value;
					const btn = document.getElementById('login-btn');

					if (!email || !password) {
						showError('Please enter email and password');
						return;
					}

					clearError();
					btn.disabled = true;
					btn.textContent = 'Signing in...';

					try {
						const res = await fetch('/login-mobile', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ email, password, signed_request: signedRequest })
						});
						const data = await res.json();

						if (data.mfa_required) {
							mfaToken = data.mfa_token;
							showMfaSection();
						} else if (data.success && data.html) {
							renderApp(data.html);
						} else {
							showError(data.error || 'Login failed');
						}
					} catch (e) {
						console.error('Login error:', e);
						showError('Network error. Please try again.');
					} finally {
						btn.disabled = false;
						btn.textContent = 'Login';
					}
				});

				document.getElementById('mfa-btn').addEventListener('click', async () => {
					const otp = document.getElementById('otp').value.trim();
					const btn = document.getElementById('mfa-btn');

					if (!otp || otp.length !== 6) {
						showError('Please enter the 6-digit code');
						return;
					}

					clearError();
					btn.disabled = true;
					btn.textContent = 'Verifying...';

					try {
						const res = await fetch('/login-mobile-mfa', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ mfa_token: mfaToken, otp, signed_request: signedRequest })
						});
						const data = await res.json();

						if (data.success && data.html) {
							renderApp(data.html);
						} else if (data.expired) {
							showError(data.error);
							setTimeout(showCredentialsSection, 2000);
						} else {
							showError(data.error || 'Invalid code');
						}
					} catch (e) {
						console.error('MFA error:', e);
						showError('Network error. Please try again.');
					} finally {
						btn.disabled = false;
						btn.textContent = 'Verify';
					}
				});

				// Submit on Enter key
				document.getElementById('password').addEventListener('keydown', (e) => {
					if (e.key === 'Enter') document.getElementById('login-btn').click();
				});
				document.getElementById('otp').addEventListener('keydown', (e) => {
					if (e.key === 'Enter') document.getElementById('mfa-btn').click();
				});
			})();
		</script>

		<% } else { %>

		<div>access_token = <span id="oauth"></span></div>
		<div><a id="loginAuth0" href="#" onclick="window.open('/login','auth0login','width=600,height=700'); return false;">Login Auth0</a><br /></div>
		<script>
			window.addEventListener('message', function(e) {
				if (e.data === 'auth0-success') {
					window.location.href = '/';
				}
			});
		</script>

		<% } %>
	</body>
</html>
