<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Canvas Demo </title>
</head>

<body>
    <div>
        <div>
            <h4>Canvas App Working as Expected, Few Observations</h4>
            <p>
                <ul>
                    <li>OAuth setting needed in Connected App for scope but no use of Callback URL.</li>
                    <li>Users must be preapproved for signed request, otherwise OAuth flow would be needed.</li> 
                </ul> 
            </p> 
        </div>  
        <p>
            <div>
                <form action="/updateAccount" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                    <input type="hidden" name="recordId" value="<%- recordId -%>" />
                    <% if (typeof signedRequest !== 'undefined' && signedRequest) { %>
                    <input type="hidden" name="signed_request" value="<%= signedRequest %>" />
                    <% } %>
                    <label for="fname">Account name:</label><br/>
                    <input type="input" name="accountName" value="<%- accountName -%>" />
                    <input type="submit" value="Submit">
                </form>                
            </div>
            <div>
                <form id="logout-form" action="/logout" method="POST">
                    <% if (typeof signedRequest !== 'undefined' && signedRequest) { %>
                    <input type="hidden" name="signed_request" value="<%= signedRequest %>" />
                    <% } %>
                    <button type="submit" style="background:none;border:none;padding:0;color:#0070d2;cursor:pointer;text-decoration:underline;font-size:inherit;">Logout</button>
                </form>
            </div>
        </p>
    </div>        
</body> 
</html>