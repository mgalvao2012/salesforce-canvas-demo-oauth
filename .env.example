# Salesforce Canvas
CANVAS_CONSUMER_SECRET=your_canvas_consumer_secret_here
# The Salesforce org instance hostname (e.g. mycompany.my.salesforce.com)
SALESFORCE_DOMAIN=your-org-instance.my.salesforce.com

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id
AUTH0_CLIENT_SECRET=your_auth0_client_secret
# Auth0 database connection name (default: Username-Password-Authentication)
AUTH0_CONNECTION=Username-Password-Authentication

# App
# Public base URL used for OAuth callback and postMessage origin
URL=localhost-url-for-oauth-callback-and-postmessage-origin
PORT=3000
# Set to "true" to serve over HTTPS using certs/localhost.pem
LOCAL_HTTPS=true
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_strong_random_string
